# Sentintern AI - Environment Variables Template

# Security
# Run 'openssl rand -hex 32' to generate a secure secret key
SECRET_KEY=your-256-bit-secret-key-here
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Application
HOST=127.0.0.1
PORT=8000
DEBUG=True

# Model Path (Absolute or Relative to src/)
MODEL_PATH=../models/finetuned_distilbert
